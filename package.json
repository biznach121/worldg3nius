{
  "name": "worldg3nius",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -k -n mock,next -c blue,magenta \"cimplify-mock --seed fashion --quiet\" \"next dev\"",
    "dev:storefront": "next dev",
    "dev:mock": "cimplify-mock --seed fashion",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "check:brand": "vitest run __tests__/brand.test.ts",
    "check:cart": "vitest run __tests__/cart-flow.test.ts",
    "check:contract": "vitest run __tests__/contract.test.ts",
    "check:visual": "playwright test",
    "check:visual:update": "playwright test --update-snapshots",
    "check": "bun run typecheck && bun run test:run"
  },
  "dependencies": {
    "@cimplify/sdk": "^0.70.3",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
